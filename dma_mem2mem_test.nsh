#:
:# DMA 内存到内存传输测试脚本
:# 基于 x86 系统 DMA 功能与 UEFI Shell 操作指南 第3.3章
:# 功能：通过 DMA 控制器将 512 字节数据从 0x100000 搬运到 0x200000
:# 用法：在 UEFI Shell 中执行  fs0:\dma_mem2mem_test.nsh
:# 注意：mm 命令地址为十六进制，无需 0x 前缀；-w 1 按字节访问
:#:

echo ====================================================================
echo  DMA Memory-to-Memory Transfer Test Script
echo  Source:      0x100000
echo  Destination: 0x200000
echo  Size:        512 bytes (0x200)
echo ====================================================================
echo.

:# ============================================================
:# Step 0 - 读取 DMA 初始状态
:# ============================================================
echo [Step 0] 读取 DMA1 状态寄存器 (0x08)...
echo # mm 8 -w 1 -io
mm 8 -w 1 -io
echo.

:# ============================================================
:# Step 1 - 复位 DMA 控制器（主清除）
:# ============================================================
echo [Step 1] 复位 DMA 控制器 - 向端口 0x0D 写入主清除...
echo # mm 0D FF -w 1 -io
mm 0D FF -w 1 -io
echo.

:# ============================================================
:# Step 2 - 设置命令寄存器：开启内存到内存模式
:# 位1=1 -> 0x02
:# ============================================================
echo [Step 2] 设置命令寄存器 (0x08) - 开启内存到内存模式 (0x02)...
echo # mm 8 02 -w 1 -io
mm 8 02 -w 1 -io
echo.

:# ============================================================
:# Step 3 - 设置通道 0 模式：块传输，地址递增，读内存
:# 模式值 = 0x84 (bit7=1 块传输, bit6=0 地址递增, bit2=0 读传输, bit1:0=00 通道0)
:# ============================================================
echo [Step 3] 设置通道 0 模式 (0x0B) - 读内存，块传输，地址递增 (0x84)...
echo # mm B 84 -w 1 -io
mm B 84 -w 1 -io
echo.

:# ============================================================
:# Step 4 - 设置通道 1 模式：块传输，地址递增，写内存
:# 模式值 = 0x85 (bit7=1 块传输, bit6=0 地址递增, bit3:2=01 写传输, bit1:0=01 通道1)
:# ============================================================
echo [Step 4] 设置通道 1 模式 (0x0B) - 写内存，块传输，地址递增 (0x85)...
echo # mm B 85 -w 1 -io
mm B 85 -w 1 -io
echo.

:# ============================================================
:# Step 5 - 设置源地址（通道 0）
:# 页面寄存器 0x87 写入高 8 位：0x100000 >> 16 = 0x10
:# 地址寄存器 0x00 写入低 16 位：先低字节 0x00，再高字节 0x00
:# ============================================================
echo [Step 5] 设置源地址 (通道 0) -> 0x100000 ...
echo # 页面寄存器 0x87 <- 0x10
mm 87 10 -w 1 -io
echo # 地址寄存器 0x00 <- 低字节 0x00
mm 0 00 -w 1 -io
echo # 地址寄存器 0x00 <- 高字节 0x00
mm 0 00 -w 1 -io
echo.

:# ============================================================
:# Step 6 - 设置目标地址（通道 1）
:# 页面寄存器 0x83 写入高 8 位：0x200000 >> 16 = 0x20
:# 地址寄存器 0x02 写入低 16 位：先低字节 0x00，再高字节 0x00
:# ============================================================
echo [Step 6] 设置目标地址 (通道 1) -> 0x200000 ...
echo # 页面寄存器 0x83 <- 0x20
mm 83 20 -w 1 -io
echo # 地址寄存器 0x02 <- 低字节 0x00
mm 2 00 -w 1 -io
echo # 地址寄存器 0x02 <- 高字节 0x00
mm 2 00 -w 1 -io
echo.

:# ============================================================
:# Step 7 - 设置传输计数（512 字节，计数 = 0x200 - 1 = 0x1FF）
:# 通道 0 计数端口 0x01：先写低字节 0xFF，再写高字节 0x01
:# 通道 1 计数端口 0x03：先写低字节 0xFF，再写高字节 0x01
:# ============================================================
echo [Step 7] 设置传输计数 - 512 bytes (0x1FF) ...
echo # 通道 0 计数端口 0x01 <- 低字节 0xFF
mm 1 FF -w 1 -io
echo # 通道 0 计数端口 0x01 <- 高字节 0x01
mm 1 01 -w 1 -io
echo # 通道 1 计数端口 0x03 <- 低字节 0xFF
mm 3 FF -w 1 -io
echo # 通道 1 计数端口 0x03 <- 高字节 0x01
mm 3 01 -w 1 -io
echo.

:# ============================================================
:# Step 8 - 清除通道 0 和通道 1 的屏蔽
:# 端口 0x0A，通道 0 写 0x00，通道 1 写 0x01
:# ============================================================
echo [Step 8] 清除通道 0 和通道 1 的屏蔽 ...
echo # 清除通道 0 屏蔽 (端口 0x0A <- 0x00)
mm A 00 -w 1 -io
echo # 清除通道 1 屏蔽 (端口 0x0A <- 0x01)
mm A 01 -w 1 -io
echo.

:# ============================================================
:# Step 9 - 软件触发 DMA 传输（通道 0 产生 DREQ）
:# 端口 0x09 写入 0x04
:# ============================================================
echo [Step 9] 软件触发 DMA 传输 (通道 0 DREQ) ...
echo # 请求寄存器 0x09 <- 0x04
mm 9 04 -w 1 -io
echo.

:# ============================================================
:# Step 10 - 检测传输完成
:# 读取状态寄存器 0x08，位 0 = 1 表示通道 0 终止计数（TC）
:# ============================================================
echo [Step 10] 检测传输完成 - 读取状态寄存器 (0x08) ...
echo # 若返回值位 0 为 1，则通道 0 TC 发生，传输完成
mm 8 -w 1 -io
echo.

:# ============================================================
:# Step 11 - 验证传输结果
:# 分别读取源地址和目标地址的前 4 字节，对比是否一致
:# ============================================================
echo [Step 11] 验证传输结果 ...
echo # 读取源地址 0x100000 前 4 字节
mm 100000 -w 4 -mem
echo # 读取目标地址 0x200000 前 4 字节
mm 200000 -w 4 -mem
echo.

echo ====================================================================
echo  DMA transfer sequence completed.
echo  Compare the two values above - if they match, transfer succeeded.
echo ====================================================================
